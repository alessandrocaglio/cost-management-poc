# ── Red Hat Cost Management API credentials ──────────────────────────────────
# Required for production (OAuth2 client credentials flow).
# Obtain a service account at: https://console.redhat.com/iam/service-accounts
COST_CLIENT_ID=your-client-id-here
COST_CLIENT_SECRET=your-client-secret-here

# ── Development shortcut ──────────────────────────────────────────────────────
# Set this to bypass OAuth2 and use a short-lived bearer token directly.
# Get one with the curl command in docs/curl-examples.md, then:
#   make dev-token TOKEN=<value>   or   python3 run_server.py --token <value>
# OVERRIDE_TOKEN=eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Red Hat API endpoints (change only if using a private instance) ────────────
SSO_TOKEN_URL=https://sso.redhat.com/auth/realms/redhat-external/protocol/openid-connect/token
COST_API_BASE_URL=https://console.redhat.com/api/cost-management/v1

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=900

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS (comma-separated origins, or * for all) ─────────────────────────────
# Use * for development; restrict to specific origins in production.
CORS_ORIGINS=*
